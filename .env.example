# ── Backend ───────────────────────────────────────────────────────────────────
NHTSA_BASE_URL=https://vpic.nhtsa.dot.gov/api/vehicles
GEMINI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE=price_xxx
STRIPE_PRICE_VIN_PASS=price_xxx
FRONTEND_URL=http://localhost:3000

# Vector store backend: "chromadb" or "mock"
VECTOR_STORE=chromadb
CHROMA_DB_PATH=./data/chroma_db

# Use Gemini embeddings instead of default ChromaDB embeddings
USE_GEMINI_EMBEDDINGS=true

# Pinecone (only needed when VECTOR_STORE=pinecone)
PINECONE_API_KEY=
PINECONE_INDEX=

# Logging: "dev" (colored console) or "json" (structured for prod)
LOG_FORMAT=dev

# Database (SQLite for local dev; e.g. postgresql://user:pass@host/db in prod)
DATABASE_URL=
# Signs user auth JWTs -- always set a real secret outside local dev
JWT_SECRET_KEY=supersecretkeyforlocalkey

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
