# ── Backend ───────────────────────────────────────────────────────────────────
# "development" (default), "test", "staging", or "production". staging/production
# refuse to start unless RESEND_API_KEY is set -- see backend/core/config.py.
ENVIRONMENT=development
NHTSA_BASE_URL=https://vpic.nhtsa.dot.gov/api/vehicles
GEMINI_API_KEY=
# Magic-link auth email delivery (Resend, https://resend.com). Unset in dev --
# request-link returns the sign-in link directly in the API response instead.
# Required in staging/production; sending to real users needs a verified
# domain (free) since the default onboarding@resend.dev sender only delivers
# to your own Resend account email. See backend/services/email.py.
RESEND_API_KEY=
EMAIL_FROM=RAPP <onboarding@resend.dev>
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE=price_xxx
STRIPE_PRICE_VIN_PASS=price_xxx

# Polar Merchant of Record (MoR) Settings
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_TIER_1=prod_tier1
POLAR_PRODUCT_ID_TIER_2=prod_tier2
POLAR_PRODUCT_ID_TIER_3=prod_tier3
POLAR_PRODUCT_ID_ANNUAL=prod_annual
FRONTEND_URL=http://localhost:3000

# Vector store backend: "chromadb" or "mock"
VECTOR_STORE=chromadb
CHROMA_DB_PATH=./data/chroma_db

# Use Gemini embeddings instead of default ChromaDB embeddings
USE_GEMINI_EMBEDDINGS=true

# Pinecone (only needed when VECTOR_STORE=pinecone)
PINECONE_API_KEY=
PINECONE_INDEX=

# Logging: "dev" (colored console) or "json" (structured for prod)
LOG_FORMAT=dev

# Database (SQLite for local dev; e.g. postgresql://user:pass@host/db in prod)
DATABASE_URL=
# Signs user auth JWTs -- always set a real secret outside local dev
JWT_SECRET_KEY=supersecretkeyforlocalkey

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
