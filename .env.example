# ── Backend ───────────────────────────────────────────────────────────────────
NHTSA_BASE_URL=https://vpic.nhtsa.dot.gov/api/vehicles
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE=price_xxx
STRIPE_PRICE_VIN_PASS=price_xxx
FRONTEND_URL=http://localhost:3000

# Vector store backend: "chromadb" or "mock"
VECTOR_STORE=chromadb
CHROMA_DB_PATH=./data/chroma_db

# Pinecone (only needed when VECTOR_STORE=pinecone)
PINECONE_API_KEY=
PINECONE_INDEX=

# Logging: "dev" (colored console) or "json" (structured for prod)
LOG_FORMAT=dev

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Firebase (client-side auth + Firestore, used by /garage and post-repair signup) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Set to "true" to connect to the Firebase Local Emulator Suite instead of a real project
NEXT_PUBLIC_FIREBASE_USE_EMULATOR=
