{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "./.venv/bin/python3",
      "runtimeArgs": ["-m", "uvicorn", "backend.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "./frontend/node_modules/.bin/next",
      "runtimeArgs": ["dev", "frontend", "-p", "3000"],
      "port": 3000
    }
  ]
}
