# Python / Poetry
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.log
# Trailing-slash form only matches real directories -- data/ is now a
# symlink to an SSD-hosted location (machine-specific absolute path, must
# never be committed), so also match the bare name to cover that case.
data/
data
# Pre-migration backups (e.g. data.bak_pre_ssd_migration_YYYY-MM-DD) --
# never delete these without explicit confirmation; they hold whatever
# existed before a data/ symlink migration (may include real DB rows).
data.bak_*

# Environment secrets — never commit these
.env
.env.local
.env.production
.env.staging

# Node / Next.js
node_modules/
frontend/.next/
frontend/out/
frontend/build/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Docker
.dockerenv

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test artefacts
playwright-report/
test-results/
mock_app.log

# On-site ingestion runtime artifacts (machine-specific, never committed --
# ingest_batch.log is already covered by the *.log rule above)
ingest_batch.pid
